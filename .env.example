# Copy to .env.local for local dev (used by `vercel dev`).
# In production, set this in Vercel → Project Settings → Environment Variables.

# Neon Postgres pooled connection string.
# Get it from: Neon Console → your project → Connection Details → "Pooled connection"
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require
